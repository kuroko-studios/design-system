{
  "surface": {
    "$type": "color",
    "$description": "Semantic surface roles (dark theme). Components reference these, not raw palette.",
    "page":    { "$value": "{color.ink.950}" },
    "base":    { "$value": "{color.ink.900}" },
    "raised":  { "$value": "{color.ink.850}" },
    "overlay": { "$value": "{color.ink.800}" },
    "field":   { "$value": "{color.ink.850}" }
  },

  "text": {
    "$type": "color",
    "primary":   { "$value": "{color.fog.50}" },
    "secondary": { "$value": "{color.fog.400}" },
    "muted":     { "$value": "{color.fog.500}" },
    "on-accent": { "$value": "{color.pure.white}" }
  },

  "line": {
    "$type": "color",
    "default": { "$value": "{color.ink.700}" },
    "strong":  { "$value": "{color.ink.600}" }
  },

  "accent": {
    "$type": "color",
    "$description": "Primary = violet (glowing). Secondary = blue, for the blue/purple duo and gradients.",
    "default":   { "$value": "{color.violet.500}" },
    "hover":     { "$value": "{color.violet.400}" },
    "pressed":   { "$value": "{color.violet.600}" },
    "text":      { "$value": "{color.violet.300}" },
    "tint":      { "$value": "{color.violet.tint}" },
    "secondary": { "$value": "{color.blue.500}" },
    "secondary-text": { "$value": "{color.blue.400}" }
  },

  "status": {
    "$type": "color",
    "ok":            { "$value": "{color.green.500}" },
    "ok-tint":       { "$value": "{color.green.tint}" },
    "warning":       { "$value": "{color.amber.500}" },
    "warning-tint":  { "$value": "{color.amber.tint}" },
    "danger":        { "$value": "{color.rose.500}" },
    "danger-tint":   { "$value": "{color.rose.tint}" }
  },

  "focus": {
    "$type": "color",
    "ring": { "$value": "{color.violet.500}" }
  }
}
